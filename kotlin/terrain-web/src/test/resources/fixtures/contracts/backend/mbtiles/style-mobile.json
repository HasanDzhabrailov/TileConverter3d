{
  "version": 8,
  "name": "Sample Tileset",
  "sources": {
    "tileset": {
      "type": "raster",
      "tiles": [
        "http://testserver/api/mbtiles/tileset-fixed/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "bounds": [
        10.0,
        20.0,
        11.0,
        21.0
      ],
      "minzoom": 4,
      "maxzoom": 12,
      "attribution": "Sample attribution"
    },
    "base-map": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 19,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "base-map",
      "type": "raster",
      "source": "base-map"
    },
    {
      "id": "tileset-raster",
      "type": "raster",
      "source": "tileset"
    }
  ],
  "center": [
    10.5,
    20.5
  ],
  "zoom": 4
}
